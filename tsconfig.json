{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "moduleResolution": "NodeNext",
    "types": [
      "node",
      "vscode"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}